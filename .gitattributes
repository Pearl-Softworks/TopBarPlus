# Normalize line endings across platforms
* text=auto eol=lf

# Luau / Lua
*.luau text eol=lf linguist-language=Lua
*.lua text eol=lf linguist-language=Lua

# Web and config
*.js text eol=lf
*.json text eol=lf
*.toml text eol=lf
*.html text eol=lf linguist-detectable=false

# Docs
*.md text diff=markdown eol=lf

# Images (README gallery, etc.)
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary

# Generated build artifacts (if ever committed)
generated/** linguist-generated=true